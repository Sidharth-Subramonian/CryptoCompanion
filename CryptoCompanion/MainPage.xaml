<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CryptoCompanion.MainPage">

    <Grid BackgroundColor="{StaticResource PageBg}">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0E1A" Offset="0.1"/>
                <GradientStop Color="#1E1B4B" Offset="0.8"/>
                <GradientStop Color="#2B0B98" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <ScrollView>
            <VerticalStackLayout Padding="30,80" Spacing="40" VerticalOptions="Center">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="CryptoCompanion" Style="{StaticResource HeadlineLabelStyle}" TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Label Text="AI-Powered Crypto Intelligence Engine" Style="{StaticResource SubHeadlineLabelStyle}" TextColor="{StaticResource Accent}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                
                <Border BackgroundColor="{StaticResource CardBgLight}" Stroke="{StaticResource Secondary}" StrokeThickness="2" StrokeShape="RoundRectangle 20" Padding="30" Margin="20,0">
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label Text="Ready to enter the market?" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center"/>
                        <Button x:Name="EnterBtn" Text="Access Dashboard" BackgroundColor="{StaticResource Primary}" TextColor="{StaticResource White}" CornerRadius="12" Padding="20,12" Clicked="OnCounterClicked" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
