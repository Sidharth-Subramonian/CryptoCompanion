<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             x:DataType="viewmodels:SentimentViewModel"
             x:Class="CryptoCompanion.Views.SentimentPage"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30,20">
            
            <Label Text="Social Sentiment Tracker" Style="{StaticResource HeadlineLabelStyle}" />
            <Label Text="Analyzing Twitter &amp; Reddit via Logistic Regression" Style="{StaticResource SubHeadlineLabelStyle}" />
            
            <Frame BackgroundColor="#1E1E1E" CornerRadius="12" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Global Market Sentiment" TextColor="White" FontSize="18" FontAttributes="Bold" />
                    
                    <Grid ColumnDefinitions="*,*,*">
                        <Label Grid.Column="0" Text="Bearish" TextColor="#FF4D4D" HorizontalOptions="Start" />
                        <Label Grid.Column="1" Text="Neutral" TextColor="#CCCCCC" HorizontalOptions="Center" />
                        <Label Grid.Column="2" Text="Bullish" TextColor="#4CAF50" HorizontalOptions="End" />
                    </Grid>
                    
                    <ProgressBar Progress="0.8" ProgressColor="#4CAF50" HeightRequest="15" />
                    <Label Text="Current Status: Extremely Bullish (80%)" TextColor="White" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>
            
            <Label Text="Recent Live Tweets" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0" />
            
            <Frame BorderColor="LightGray" CornerRadius="8" Padding="15">
                <VerticalStackLayout>
                    <Label Text="@CryptoWhale123" FontSize="12" TextColor="Gray" />
                    <Label Text="$BTC is looking incredibly bullish right now! Going to the moon! 🚀" Margin="0,5" />
                    <Label Text="Classification: Bullish (99% confidence)" TextColor="Green" FontSize="12" />
                </VerticalStackLayout>
            </Frame>
            
            <Frame BorderColor="LightGray" CornerRadius="8" Padding="15">
                <VerticalStackLayout>
                    <Label Text="@MarketSkeptic" FontSize="12" TextColor="Gray" />
                    <Label Text="The market looks terrible, I'm selling everything." Margin="0,5" />
                    <Label Text="Classification: Bearish (95% confidence)" TextColor="Red" FontSize="12" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
