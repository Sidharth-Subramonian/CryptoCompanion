<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             xmlns:models="clr-namespace:CryptoCompanion.Models"
             xmlns:converters="clr-namespace:CryptoCompanion.Converters"
             x:DataType="viewmodels:SentimentViewModel"
             x:Class="CryptoCompanion.Views.SentimentPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:SentimentToColorConverter x:Key="SentimentToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24,20">

            <!-- Header -->
            <Label Text="🧠 Sentiment Tracker" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Market sentiment derived from crypto news analysis"
                   FontSize="13" TextColor="{StaticResource TextSecondary}" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="↻  Refresh"
                        Command="{Binding LoadSentimentCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        CornerRadius="10" Padding="18,10" FontSize="13" />
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Accent}" HorizontalOptions="Start" />
            </Grid>

            <!-- Sentiment Dashboard Card -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    Stroke="{StaticResource Gray600}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="24">
                <VerticalStackLayout Spacing="16">
                    <Label Text="GLOBAL MARKET SENTIMENT" FontSize="11" FontAttributes="Bold"
                           TextColor="{StaticResource TextMuted}" />

                    <!-- Sentiment Bars -->
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                        <!-- Bullish -->
                        <Grid Grid.Row="0" ColumnDefinitions="80,*,50">
                            <Label Grid.Column="0" Text="Bullish" FontSize="13"
                                   TextColor="{StaticResource GreenNeon}" FontAttributes="Bold" />
                            <Border Grid.Column="1" BackgroundColor="{StaticResource CardBgLight}"
                                    StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                    HeightRequest="24">
                                <ProgressBar Progress="{Binding BullishPercent}"
                                             ProgressColor="{StaticResource GreenNeon}"
                                             VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="2" Text="{Binding BullishPercent, StringFormat='{0:P0}'}"
                                   FontSize="13" TextColor="{StaticResource GreenNeon}"
                                   HorizontalOptions="End" FontAttributes="Bold" />
                        </Grid>
                        <!-- Neutral -->
                        <Grid Grid.Row="1" ColumnDefinitions="80,*,50">
                            <Label Grid.Column="0" Text="Neutral" FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" />
                            <Border Grid.Column="1" BackgroundColor="{StaticResource CardBgLight}"
                                    StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                    HeightRequest="24">
                                <ProgressBar Progress="{Binding NeutralPercent}"
                                             ProgressColor="{StaticResource TextSecondary}"
                                             VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="2" Text="{Binding NeutralPercent, StringFormat='{0:P0}'}"
                                   FontSize="13" TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="End" FontAttributes="Bold" />
                        </Grid>
                        <!-- Bearish -->
                        <Grid Grid.Row="2" ColumnDefinitions="80,*,50">
                            <Label Grid.Column="0" Text="Bearish" FontSize="13"
                                   TextColor="{StaticResource RedNeon}" FontAttributes="Bold" />
                            <Border Grid.Column="1" BackgroundColor="{StaticResource CardBgLight}"
                                    StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                    HeightRequest="24">
                                <ProgressBar Progress="{Binding BearishPercent}"
                                             ProgressColor="{StaticResource RedNeon}"
                                             VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="2" Text="{Binding BearishPercent, StringFormat='{0:P0}'}"
                                   FontSize="13" TextColor="{StaticResource RedNeon}"
                                   HorizontalOptions="End" FontAttributes="Bold" />
                        </Grid>
                    </Grid>

                    <!-- Status Line -->
                    <BoxView HeightRequest="1" Color="{StaticResource Gray600}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{Binding SentimentStatus}"
                               TextColor="{StaticResource TextPrimary}" FontSize="14"
                               FontAttributes="Bold" />
                        <Label Grid.Column="1"
                               Text="{Binding TotalPosts, StringFormat='{0} posts analyzed'}"
                               TextColor="{StaticResource TextMuted}" FontSize="12" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Posts Section -->
            <Label Text="RECENT POSTS" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="0,4,0,0" />

            <CollectionView ItemsSource="{Binding SentimentPosts}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SocialSentiment">
                        <Border BackgroundColor="{StaticResource CardBg}"
                                Stroke="{StaticResource Gray600}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Padding="16" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Label Grid.Column="0"
                                           Text="{Binding Author, StringFormat='@{0}'}"
                                           FontSize="12" TextColor="{StaticResource TextMuted}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding PostedAt, StringFormat='{0:MMM dd, HH:mm}'}"
                                           FontSize="10" TextColor="{StaticResource TextMuted}"
                                           VerticalOptions="Center" />
                                    <Border Grid.Column="2" BackgroundColor="{StaticResource CardBgLight}"
                                            StrokeShape="RoundRectangle 6" Padding="8,3"
                                            Stroke="Transparent">
                                        <Label Text="{Binding CoinSymbol}" FontSize="11"
                                               TextColor="{StaticResource Accent}"
                                               FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <Label Text="{Binding Content}" FontSize="13"
                                       TextColor="{StaticResource TextPrimary}"
                                       MaxLines="2" LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding SentimentClass}" FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{Binding SentimentClass, Converter={StaticResource SentimentToColorConverter}}" />
                                    <Label Text="{Binding Confidence, StringFormat='({0:P0})'}"
                                           FontSize="12" TextColor="{StaticResource TextMuted}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
