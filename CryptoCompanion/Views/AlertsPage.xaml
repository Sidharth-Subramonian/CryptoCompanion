<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             x:DataType="viewmodels:AlertsViewModel"
             x:Class="CryptoCompanion.Views.AlertsPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Spacing="10" Padding="20">
            <Label Text="Anomaly Alerts" Style="{StaticResource HeadlineLabelStyle}" />
            <Label Text="Powered by Isolation Forests &amp; SVM" FontSize="14" TextColor="Gray" />
        </VerticalStackLayout>
        
        <CollectionView Grid.Row="1" ItemsSource="{Binding ActiveAlerts}" Padding="20">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#FF4D4D" CornerRadius="8" Padding="15" Margin="0,0,0,15" BackgroundColor="#1A1A1A">
                        <VerticalStackLayout Spacing="5">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Title}" FontAttributes="Bold" FontSize="18" TextColor="White" />
                                <Label Grid.Column="1" Text="{Binding Time}" FontSize="12" TextColor="Gray" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="{Binding Message}" FontSize="14" TextColor="White" Margin="0,5" />
                            <Label Text="{Binding Algorithm, StringFormat='Detector: {0}'}" FontSize="12" TextColor="#4CAF50" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
