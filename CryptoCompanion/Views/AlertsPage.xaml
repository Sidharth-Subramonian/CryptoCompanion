<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             xmlns:models="clr-namespace:CryptoCompanion.Models"
             x:DataType="viewmodels:AlertsViewModel"
             x:Class="CryptoCompanion.Views.AlertsPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="12" Padding="24,20,24,12">
            <Label Text="🚨 Anomaly Alerts" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Real-time price &amp; volume anomaly detection"
                   FontSize="13" TextColor="{StaticResource TextSecondary}" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="↻  Refresh"
                        Command="{Binding LoadAlertsCommand}"
                        BackgroundColor="{StaticResource RedNeon}"
                        CornerRadius="10" Padding="18,10" FontSize="13" />
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource RedNeon}" HorizontalOptions="Start" />
            </Grid>
        </VerticalStackLayout>

        <!-- Alert Cards -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding ActiveAlerts}" Margin="24,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AlertItem">
                    <Border BackgroundColor="{StaticResource CardBg}"
                            Stroke="{StaticResource RedDim}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Margin="0,0,0,12">
                        <VerticalStackLayout Spacing="10" Padding="20">
                            <!-- Title + Time -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Title}"
                                       FontAttributes="Bold" FontSize="16"
                                       TextColor="{StaticResource RedNeon}" />
                                <Border Grid.Column="1" BackgroundColor="{StaticResource CardBgLight}"
                                        StrokeShape="RoundRectangle 6" Padding="8,3"
                                        Stroke="Transparent">
                                    <Label Text="{Binding Time}" FontSize="10"
                                           TextColor="{StaticResource TextMuted}" />
                                </Border>
                            </Grid>

                            <!-- Message -->
                            <Label Text="{Binding Message}" FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />

                            <!-- Algorithm Badge -->
                            <Border BackgroundColor="{StaticResource GreenDim}"
                                    StrokeShape="RoundRectangle 8" Padding="10,5"
                                    Stroke="Transparent" HorizontalOptions="Start">
                                <Label Text="{Binding Algorithm, StringFormat='⚙ {0}'}"
                                       FontSize="11" TextColor="{StaticResource GreenNeon}"
                                       FontAttributes="Bold" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Border BackgroundColor="{StaticResource CardBg}"
                        StrokeShape="RoundRectangle 14" Stroke="{StaticResource Gray600}"
                        Padding="30" HorizontalOptions="Fill" Margin="0,20">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="✅" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="All Clear" FontSize="16"
                               TextColor="{StaticResource GreenNeon}"
                               HorizontalOptions="Center" FontAttributes="Bold" />
                        <Label Text="No anomalies detected in current market data"
                               FontSize="12" TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
