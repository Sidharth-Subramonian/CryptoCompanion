<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             xmlns:converters="clr-namespace:CryptoCompanion.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:DataType="viewmodels:PortfolioViewModel"
             x:Class="CryptoCompanion.Views.PortfolioPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24,20">

            <!-- Header -->
            <Label Text="💼 Portfolio" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />

            <!-- Total Value Card with Glowing Gradient -->
            <Border StrokeThickness="1" StrokeShape="RoundRectangle 20" Padding="24">
                <Border.Stroke>
                     <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                        <GradientStop Color="#00000000" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Stroke>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A2332" Offset="0.0" />
                        <GradientStop Color="#0A0E1A" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="8">
                    <Label Text="TOTAL BALANCE" FontSize="11" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" CharacterSpacing="1" />
                    <Label Text="{Binding TotalValueDisplay}"
                           FontSize="42" FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Connected to LIVE exchanges"
                           FontSize="12" TextColor="{StaticResource Accent}" />
                </VerticalStackLayout>
            </Border>

            <!-- AI Risk Analysis Card -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    Stroke="{StaticResource Secondary}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="24">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🤖" FontSize="20" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                            <Label Text="AI RISK ANALYSIS" FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource TextMuted}" />
                            <Label Text="K-Means clustering on volatility &amp; returns"
                                   FontSize="11" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="▶  Analyze Risk"
                            Command="{Binding AnalyzePortfolioRiskCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            CornerRadius="10" Padding="18,10" FontSize="13" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Accent}" />

                    <!-- Risk Result -->
                    <Border BackgroundColor="{StaticResource CardBgLight}"
                            StrokeShape="RoundRectangle 10" Padding="14,10"
                            Stroke="Transparent" IsVisible="True">
                        <Label Text="{Binding PortfolioRiskAnalysis}"
                               TextColor="{StaticResource YellowNeon}"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Exchange Integration Card -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    Stroke="{StaticResource Primary}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="24">
                <VerticalStackLayout Spacing="12">
                    <Label Text="COINDCX INTEGRATION" FontSize="11" FontAttributes="Bold"
                           TextColor="{StaticResource TextMuted}" />
                    
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsLinked}">
                        <Label Text="Account Linked Status: Active 🟢" TextColor="{StaticResource GreenNeon}" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="Unlink" Command="{Binding UnlinkAccountCommand}" BackgroundColor="{StaticResource CardBgLight}" TextColor="{StaticResource RedNeon}" CornerRadius="6" Padding="10,5" FontSize="12" />
                    </Grid>

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding IsLinked, Converter={x:StaticResource InvertedBoolConverter}}">
                        <Border BackgroundColor="{StaticResource CardBgLight}" StrokeShape="RoundRectangle 8" Padding="10,0" StrokeThickness="0">
                            <Entry Text="{Binding CoinDcxApiKey}" Placeholder="API Key" PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource CardBgLight}" StrokeShape="RoundRectangle 8" Padding="10,0" StrokeThickness="0">
                            <Entry Text="{Binding CoinDcxApiSecret}" Placeholder="API Secret" IsPassword="True" PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}" />
                        </Border>
                        <Button Text="Connect Account" Command="{Binding LinkCoinDcxAccountCommand}" BackgroundColor="{StaticResource Primary}" CornerRadius="10" Padding="18,10" FontSize="13" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Holdings Section -->
            <Label Text="PORTFOLIO ALLOCATION" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="0,10,0,0" CharacterSpacing="1" />
            
            <lvc:PieChart Series="{Binding PortfolioSeries}" HeightRequest="250" Margin="0,10,0,20"/>
            
            <CollectionView ItemsSource="{Binding Assets}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:PortfolioAsset">
                        <Border BackgroundColor="{StaticResource CardBg}"
                                Stroke="{StaticResource Gray600}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Padding="16" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="60,*,Auto" RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12" RowSpacing="6">
                                <!-- Symbol -->
                                <Border Grid.RowSpan="2" BackgroundColor="{StaticResource CardBgLight}"
                                        StrokeShape="RoundRectangle 10" Padding="0"
                                        Stroke="Transparent"
                                        HeightRequest="44" WidthRequest="44"
                                        VerticalOptions="Center" HorizontalOptions="Center">
                                    <Label Text="{Binding Symbol}" FontAttributes="Bold"
                                           FontSize="13" TextColor="{StaticResource Accent}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <!-- Allocation bar -->
                                <Border Grid.Row="0" Grid.Column="1"
                                        BackgroundColor="{StaticResource CardBgLight}"
                                        StrokeShape="RoundRectangle 4" Stroke="Transparent"
                                        HeightRequest="8" VerticalOptions="Center">
                                    <ProgressBar Progress="{Binding Allocation}"
                                                 ProgressColor="{StaticResource Primary}" />
                                </Border>
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Allocation, StringFormat='{0:P0} allocation'}"
                                       FontSize="11" TextColor="{StaticResource TextMuted}" />
                                <!-- Value -->
                                <Label Grid.RowSpan="2" Grid.Column="2"
                                       Text="{Binding Value, StringFormat='Rs. {0:N0}'}"
                                       FontSize="18" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
