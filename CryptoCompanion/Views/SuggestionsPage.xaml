<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             x:DataType="viewmodels:SuggestionsViewModel"
             x:Class="CryptoCompanion.Views.SuggestionsPage"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30,0" VerticalOptions="Center">
            
            <Label Text="AI Forecasts" 
                   Style="{StaticResource HeadlineLabelStyle}" 
                   SemanticProperties.HeadingLevel="Level1" />
                   
            <Label Text="Predicting short-term price movements and identifying top assets based on classical ML indicators."
                   Style="{StaticResource SubHeadlineLabelStyle}" />
                   
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            
            <Button Text="Run AI Predictions" Command="{Binding RunMlPredictionsCommand}" Margin="0,10" />
            
            <Frame BackgroundColor="{StaticResource Primary}" Padding="20" CornerRadius="10">
                <VerticalStackLayout>
                    <Label Text="Bitcoin (BTC)" TextColor="White" FontSize="20" FontAttributes="Bold" />
                    <Label Text="{Binding BtcForecast}" TextColor="White" FontSize="16" />
                    <Label Text="{Binding BtcRank}" TextColor="White" FontSize="16" />
                </VerticalStackLayout>
            </Frame>
            
            <Frame BackgroundColor="{StaticResource Secondary}" Padding="20" CornerRadius="10">
                <VerticalStackLayout>
                    <Label Text="Ethereum (ETH)" TextColor="White" FontSize="20" FontAttributes="Bold" />
                    <Label Text="Linear Regression Forecast: $3,450 (+1.2%)" TextColor="White" FontSize="16" />
                    <Label Text="Random Forest Rank: #2 (Buy)" TextColor="White" FontSize="16" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
