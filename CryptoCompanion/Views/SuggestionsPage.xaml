<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CryptoCompanion.ViewModels"
             xmlns:models="clr-namespace:CryptoCompanion.Models"
             xmlns:converters="clr-namespace:CryptoCompanion.Converters"
             x:Class="CryptoCompanion.Views.SuggestionsPage"
             x:DataType="vm:SuggestionsViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrushConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16">

            <!-- Header Section -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="⚡ AI Forecasts"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Real-time ML predictions from live market data"
                           FontSize="13" TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Action Bar -->
            <Border BackgroundColor="{StaticResource CardBg}" StrokeShape="RoundRectangle 14"
                    Stroke="{StaticResource Gray600}" StrokeThickness="1" Padding="16">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                        <Label Text="ONNX Runtime Engine" FontSize="12"
                               TextColor="{StaticResource Accent}" FontAttributes="Bold" />
                        <Label Text="Price Forecast + Crypto Ranking models"
                               FontSize="11" TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="▶  Run AI"
                            Command="{Binding RunMlPredictionsCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="10" Padding="18,10" FontSize="13" />
                </Grid>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" Color="{StaticResource Accent}"
                               WidthRequest="40" HeightRequest="40" />

            <!-- Results Section Header -->
            <Label Text="PREDICTIONS" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="0,4,0,0" />

            <!-- Prediction Cards -->
            <CollectionView ItemsSource="{Binding Suggestions}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SuggestionModel">
                        <Border BackgroundColor="{StaticResource CardBg}"
                                Stroke="{StaticResource Gray600}" StrokeThickness="1"
                                Padding="20" StrokeShape="RoundRectangle 14" Margin="0,4">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <!-- Coin Name -->
                                <Label Grid.Row="0" Text="{Binding Name}"
                                       TextColor="{StaticResource Accent}"
                                       FontSize="18" FontAttributes="Bold" />
                                <!-- Forecast -->
                                <Border Grid.Row="1" BackgroundColor="{StaticResource CardBgLight}"
                                        StrokeShape="RoundRectangle 8" Padding="12,8"
                                        Stroke="Transparent">
                                    <Label Text="{Binding Forecast}"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="13" FontFamily="OpenSansRegular" />
                                </Border>
                                <!-- Rank -->
                                <Label Grid.Row="2" Text="{Binding Rank}"
                                       TextColor="{StaticResource TextSecondary}" FontSize="12" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Empty State -->
            <Border IsVisible="{Binding IsEmpty}"
                    BackgroundColor="{StaticResource CardBg}"
                    StrokeShape="RoundRectangle 14" Stroke="{StaticResource Gray600}"
                    Padding="30" HorizontalOptions="Fill">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="🔮" FontSize="32" HorizontalOptions="Center" />
                    <Label Text="No predictions yet"
                           FontSize="16" TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" />
                    <Label Text="Tap 'Run AI' to analyze live market data"
                           FontSize="12" TextColor="{StaticResource TextMuted}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>