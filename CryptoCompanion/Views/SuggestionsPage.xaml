<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CryptoCompanion.ViewModels"
             xmlns:models="clr-namespace:CryptoCompanion.Models"
             xmlns:converters="clr-namespace:CryptoCompanion.Converters"
             x:Class="CryptoCompanion.Views.SuggestionsPage"
             x:DataType="vm:SuggestionsViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrushConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Header Section with Noise/Glow Background -->
        <Border Grid.Row="0" StrokeThickness="0" Margin="0" Padding="24,30,24,20" BackgroundColor="{StaticResource PageBg}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1E1B4B" Offset="0.0"/>
                    <GradientStop Color="#0A0E1A" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <VerticalStackLayout Spacing="16">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="AI Market Intelligence"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="#E0E7FF" CharacterSpacing="1" />
                        <Label Text="{Binding AiStatusText}"
                               FontSize="14" TextColor="{StaticResource Accent}" 
                               FontAttributes="Italic" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Premium Action Bar -->
                <Border StrokeShape="RoundRectangle 20" StrokeThickness="1" Padding="20">
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6366F1" Offset="0"/>
                            <GradientStop Color="#D946EF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Stroke>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1B41" Offset="0"/>
                            <GradientStop Color="#0F172A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                            <Label Text="ONNX Neural Engine" FontSize="15"
                                   TextColor="#E0E7FF" FontAttributes="Bold" />
                            <Label Text="{Binding BtcRank}"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Run Analysis"
                                Command="{Binding RunMlPredictionsCommand}"
                                TextColor="White" FontAttributes="Bold"
                                Padding="24,12" FontSize="14"
                                CornerRadius="12">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </Grid>
                </Border>
                
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" Color="{StaticResource Accent}"
                                   WidthRequest="40" HeightRequest="40" Margin="0,10,0,0"/>

                <!-- Results Section Header -->
                <Label Text="{Binding BtcForecast}" FontSize="13" FontAttributes="Bold"
                       TextColor="{StaticResource TextMuted}" Margin="0,10,0,0" />
            </VerticalStackLayout>
        </Border>

        <!-- Dynamic Prediction Cards (Glassmorphism) -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Suggestions}" SelectionMode="None" Margin="24,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SuggestionModel">
                    <Grid Margin="0,0,0,16">
                        <!-- Glow Effect Behind Card -->
                        <Border BackgroundColor="{Binding BackgroundKey, Converter={StaticResource ResourceKeyToBrushConverter}}"
                                Opacity="0.1" StrokeThickness="0"
                                Margin="4,8,-4,-8" />
                        
                        <!-- Main Card -->
                        <Border BackgroundColor="#111827"
                                Stroke="#1E293B" StrokeThickness="1.5"
                                Padding="20">
                            <VerticalStackLayout Spacing="16">

                                <!-- Header: Coin + Risk Badge -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                        <Border HeightRequest="40" WidthRequest="40" StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#1E293B">
                                            <Label Text="💎" HorizontalOptions="Center" VerticalOptions="Center" FontSize="18"/>
                                        </Border>
                                        <Label Text="{Binding Name}" VerticalOptions="Center"
                                               TextColor="White" FontSize="20" FontAttributes="Bold" />
                                    </HorizontalStackLayout>
                                    
                                    <Border Grid.Column="1" VerticalOptions="Center"
                                            BackgroundColor="{StaticResource SurfaceBg}"
                                            StrokeShape="RoundRectangle 12" Padding="12,6"
                                            Stroke="{Binding BackgroundKey, Converter={StaticResource ResourceKeyToBrushConverter}}">
                                        <Label Text="{Binding Signal}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="{Binding BackgroundKey, Converter={StaticResource ResourceKeyToBrushConverter}}" />
                                    </Border>
                                </Grid>

                                <!-- Financials -->
                                <Grid ColumnDefinitions="*,*">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="Confidence Score" FontSize="11" TextColor="{StaticResource TextMuted}"/>
                                        <Label Text="{Binding Rank}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Accent}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="End">
                                        <Label Text="24h Projected Impact" FontSize="11" TextColor="{StaticResource TextMuted}" HorizontalOptions="End"/>
                                        <Label Text="{Binding Forecast}" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="End"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- AI Reasoning -->
                                <Border BackgroundColor="#0A0E1A" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="14">
                                     <HorizontalStackLayout Spacing="10">
                                         <Label Text="🧠" FontSize="14" VerticalOptions="Start" />
                                         <Label Text="{Binding Reasoning}" TextColor="{StaticResource TextSecondary}" FontSize="13" LineBreakMode="WordWrap" />
                                     </HorizontalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Premium Empty State -->
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,60">
                    <Border HeightRequest="100" WidthRequest="100" StrokeShape="RoundRectangle 50" StrokeThickness="1" 
                            BackgroundColor="#0A0E1A" HorizontalOptions="Center">
                        <Border.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource Accent}" Offset="0"/>
                                <GradientStop Color="{StaticResource Primary}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Stroke>
                        <Label Text="🌌" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Waiting for Signals..." FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="Initiate the Neural Engine to scan global markets and surface top picks." 
                           FontSize="14" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" HorizontalTextAlignment="Center" MaximumWidthRequest="280"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>