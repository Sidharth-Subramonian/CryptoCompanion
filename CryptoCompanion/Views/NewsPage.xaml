<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             xmlns:models="clr-namespace:CryptoCompanion.Models"
             xmlns:converters="clr-namespace:CryptoCompanion.Converters"
             x:DataType="viewmodels:NewsViewModel"
             x:Class="CryptoCompanion.Views.NewsPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:SentimentToColorConverter x:Key="SentimentToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" StrokeThickness="0" Margin="0" Padding="24,30,24,20" BackgroundColor="{StaticResource PageBg}">
            <VerticalStackLayout Spacing="16">
                <Label Text="Live Market News" FontSize="32" FontAttributes="Bold"
                       TextColor="#E0E7FF" CharacterSpacing="1" />
                
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="↻ Synchronize"
                            Command="{Binding LoadNewsCommand}"
                            TextColor="White" FontAttributes="Bold" CornerRadius="10" Padding="14,8" FontSize="13">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#4F46E5" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Accent}" HorizontalOptions="Start" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- News Feed -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding NewsArticles}" Margin="24,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NewsArticle">
                    <Border BackgroundColor="#111827"
                            Stroke="#1E293B" StrokeThickness="1"
                            StrokeShape="RoundRectangle 16" Margin="0,0,0,16">
                        <Grid ColumnDefinitions="100,*" RowDefinitions="*">
                            <!-- Image Placeholder -->
                            <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="#1E293B" Margin="12">
                                <Label Text="🖼️" HorizontalOptions="Center" VerticalOptions="Center" FontSize="24"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Padding="8,16,16,16" Spacing="8">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="15"
                                       TextColor="White" MaxLines="2" LineBreakMode="TailTruncation" />

                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding Source}" FontSize="12" TextColor="{StaticResource Accent}" FontAttributes="Bold" />
                                    <Label Text="•" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                    <Label Text="{Binding PublishedAt, StringFormat='{0:MMM dd}'}" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                </HorizontalStackLayout>

                                <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                    <!-- Sentiment Badge -->
                                    <Border Grid.Column="0" BackgroundColor="#1E1B4B" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10,4" HorizontalOptions="Start">
                                        <Label Text="{Binding SentimentLabel}" FontSize="11" TextColor="{Binding SentimentLabel, Converter={StaticResource SentimentToColorConverter}}" FontAttributes="Bold" />
                                    </Border>
                                    
                                    <Label Grid.Column="1" Text="Read →" FontSize="13" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnReadArticleTapped" CommandParameter="{Binding Url}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
