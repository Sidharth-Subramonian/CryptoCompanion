<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             x:DataType="viewmodels:NewsViewModel"
             x:Class="CryptoCompanion.Views.NewsPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Spacing="15" Padding="20">
            <Label Text="Latest News" Style="{StaticResource HeadlineLabelStyle}" />
            <Button Text="Refresh Data" Command="{Binding LoadNewsCommand}" HorizontalOptions="Start" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
        
        <CollectionView Grid.Row="1" ItemsSource="{Binding NewsArticles}" Padding="20">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <VerticalStackLayout>
                            <!-- Binding paths based on CosmosDB 'NewsArticle' schema -->
                            <Label Text="{Binding title}" FontAttributes="Bold" FontSize="18" />
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="Source:" FontSize="12" TextColor="Gray" />
                                <Label Text="{Binding source}" FontSize="12" TextColor="Gray" />
                            </HorizontalStackLayout>
                            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />
                            <Label Text="{Binding summary}" FontSize="14" Margin="0,0,0,10" MaxLines="3" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding sentimentLabel, StringFormat='ML Sentiment: {0}'}" FontSize="14" TextColor="Green" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
