<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CryptoCompanion.ViewModels"
             xmlns:models="clr-namespace:CryptoCompanion.Models"
             x:DataType="viewmodels:NewsViewModel"
             x:Class="CryptoCompanion.Views.NewsPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="12" Padding="24,20,24,12">
            <Label Text="📰 Latest News" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Real-time crypto news from CryptoCompare"
                   FontSize="13" TextColor="{StaticResource TextSecondary}" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="↻  Refresh"
                        Command="{Binding LoadNewsCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        CornerRadius="10" Padding="18,10" FontSize="13" />
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Accent}" HorizontalOptions="Start" />
            </Grid>
        </VerticalStackLayout>

        <!-- News Feed -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding NewsArticles}" Margin="24,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NewsArticle">
                    <Border BackgroundColor="{StaticResource CardBg}"
                            Stroke="{StaticResource Gray600}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Margin="0,0,0,12">
                        <VerticalStackLayout Padding="20" Spacing="10">
                            <!-- Title -->
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16"
                                   TextColor="{StaticResource TextPrimary}"
                                   MaxLines="2" LineBreakMode="TailTruncation" />

                            <!-- Source + Date Row -->
                            <HorizontalStackLayout Spacing="8">
                                <Border BackgroundColor="{StaticResource CardBgLight}"
                                        StrokeShape="RoundRectangle 6" Padding="8,4"
                                        Stroke="Transparent">
                                    <Label Text="{Binding Source}" FontSize="11"
                                           TextColor="{StaticResource Accent}" FontAttributes="Bold" />
                                </Border>
                                <Label Text="{Binding PublishedAt, StringFormat='{0:MMM dd, yyyy  •  HH:mm}'}"
                                       FontSize="11" TextColor="{StaticResource TextMuted}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Divider -->
                            <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Margin="0,2" />

                            <!-- Summary -->
                            <Label Text="{Binding Summary}" FontSize="13"
                                   TextColor="{StaticResource TextSecondary}"
                                   MaxLines="3" LineBreakMode="TailTruncation" />

                            <!-- Bottom Row: Sentiment + Link -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Border Grid.Column="0" BackgroundColor="{StaticResource GreenDim}"
                                        StrokeShape="RoundRectangle 8" Padding="10,6"
                                        Stroke="Transparent" HorizontalOptions="Start">
                                    <Label Text="{Binding SentimentLabel, StringFormat='🤖 {0}'}"
                                           FontSize="12" TextColor="{StaticResource GreenNeon}"
                                           FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Column="1" Text="Read Article →"
                                       FontSize="12" TextColor="{StaticResource Accent}"
                                       FontAttributes="Bold" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnReadArticleTapped"
                                                              CommandParameter="{Binding Url}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
