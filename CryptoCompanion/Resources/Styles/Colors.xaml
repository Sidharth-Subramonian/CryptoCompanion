<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══ DARK FUTURISTIC PALETTE ═══ -->

    <!-- Core Background -->
    <Color x:Key="PageBg">#0A0E1A</Color>
    <Color x:Key="CardBg">#111827</Color>
    <Color x:Key="CardBgLight">#1A2332</Color>
    <Color x:Key="SurfaceBg">#0F172A</Color>

    <!-- Neon Accents -->
    <Color x:Key="Primary">#6366F1</Color>
    <Color x:Key="PrimaryDark">#818CF8</Color>
    <Color x:Key="PrimaryDarkText">#E0E7FF</Color>
    <Color x:Key="Secondary">#8B5CF6</Color>
    <Color x:Key="SecondaryDarkText">#C4B5FD</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>
    <Color x:Key="Accent">#22D3EE</Color>
    <Color x:Key="AccentGlow">#06B6D4</Color>

    <!-- Status Colors -->
    <Color x:Key="GreenNeon">#10B981</Color>
    <Color x:Key="GreenDim">#064E3B</Color>
    <Color x:Key="RedNeon">#EF4444</Color>
    <Color x:Key="RedDim">#7F1D1D</Color>
    <Color x:Key="YellowNeon">#F59E0B</Color>
    <Color x:Key="YellowDim">#78350F</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#F1F5F9</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="TextMuted">#64748B</Color>

    <!-- Legacy keys (keep for compatibility) -->
    <Color x:Key="White">#F1F5F9</Color>
    <Color x:Key="Black">#0A0E1A</Color>
    <Color x:Key="Magenta">#D946EF</Color>
    <Color x:Key="MidnightBlue">#1E1B4B</Color>
    <Color x:Key="OffBlack">#0A0E1A</Color>

    <Color x:Key="Gray100">#E2E8F0</Color>
    <Color x:Key="Gray200">#CBD5E1</Color>
    <Color x:Key="Gray300">#94A3B8</Color>
    <Color x:Key="Gray400">#64748B</Color>
    <Color x:Key="Gray500">#475569</Color>
    <Color x:Key="Gray600">#334155</Color>
    <Color x:Key="Gray900">#0F172A</Color>
    <Color x:Key="Gray950">#0A0E1A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- Premium Gradients -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
        <GradientStop Color="{StaticResource Secondary}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#059669" Offset="0.0" />
        <GradientStop Color="#10B981" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B91C1C" Offset="0.0" />
        <GradientStop Color="#EF4444" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AiGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0.0" />
        <GradientStop Color="#D946EF" Offset="1.0" />
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="CardGlowGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1E293B" Offset="0.0" />
        <GradientStop Color="#0F172A" Offset="1.0" />
    </LinearGradientBrush>
</ResourceDictionary>